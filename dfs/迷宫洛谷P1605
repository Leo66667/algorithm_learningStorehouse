#include<bits/stdc++.h>
using namespace std;

int n,m,t,sx,sy,fx,fy,ans;
bool book[20][20];//是否走过（需要回溯） 
bool mp[20][20];//障碍物 （不能回溯） 
int xx[]={1,0,-1,0};
int yy[]={0,-1,0,1};
void dfs(int x,int  y){
	if(x==fx&&y==fy){
		ans++;
		return;
	}
	
	for(int i=0;i<4;i++){
		int dx=xx[i]+x;
		int dy=yy[i]+y;
		if(dx>=1&&dx<=n&&dy>=1&&dy<=m&&book[dx][dy]==0&&mp[dx][dy]==0){
			book[dx][dy]=1;
			dfs(dx,dy);
			book[dx][dy]=0;
		}
	}
	
}

int main(){
	
	cin>>n>>m>>t>>sx>>sy>>fx>>fy;
	while(t--) {
		int x ,y;
		cin>>x>>y;
		mp[x][y]=1;
		
	}
	book[sx][sy]=1;
	dfs(sx,sy); 
	cout<<ans<<endl;
	return 0;
}
