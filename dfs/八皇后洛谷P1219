//左右对角线用行和列的或差进行模拟

//八皇后问题
#include<iostream>
using namespace std;
int n,a[20],book[20],u[40],v[40],ans=0;

void dfs(int step){
	if(step>n){ans++;
	if(ans<=3){
	
	for(int i=1;i<=n;i++){
		cout<<a[i]<<" ";
		
	}
	cout<<endl;}return;
		}
		for(int i=1;i<=n;i++){
			if(book[i]==0&&u[step-i+n]==0&&v[i+step]==0)
	{
		book[i]=1;
		u[step-i+n]=1;
		v[i+step]=1;
		a[step]=i;
		dfs(step+1);
		book[i]=0;
		u[step-i+n]=0;
		v[i+step]=0;
		}	
	}
		
}

 
int main(){
	cin>>n;
	dfs(1);
	cout<<ans<<endl;
	return 0;
}
